---
import PluginsPage from "../components/PluginsPage.astro";
import SettingsPage from "../components/SettingsPage.astro";
import Layout from "../layouts/Layout.astro";
import { site } from "../lib/content";
---

<Layout variant={site.variant} title={site.title} description={site.description} canonical={site.url}>
  {site.variant === "settings" ? <SettingsPage /> : <PluginsPage />}
</Layout>
