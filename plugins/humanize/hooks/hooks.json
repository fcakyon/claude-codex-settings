{
  "description": "humanize: block matched AI buzzwords before a Write or Edit lands",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/humanize.py"
            ]
          }
        ]
      }
    ]
  }
}
