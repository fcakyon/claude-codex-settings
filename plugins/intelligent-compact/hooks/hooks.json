{
  "description": "PreCompact hook that injects priority-preservation instructions into the conversation summary",
  "hooks": {
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/precompact_priorities.sh"
          }
        ]
      }
    ]
  }
}
